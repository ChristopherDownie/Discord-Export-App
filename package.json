{
  "name": "temp-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite --port 5173 --strictPort\" \"npm run build:electron:watch\" \"npm start\"",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build:electron:watch": "tsc -w -p electron/tsconfig.json",
    "start": "wait-on tcp:5173 && cross-env NODE_ENV=development electron .",
    "build": "tsc -b && vite build && npm run build:electron",
    "build:app": "npm run build && electron-builder --mac -c.mac.identity=null",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.discordexportapp",
    "productName": "Discord Export App",
    "afterPack": "scripts/afterPack.cjs",
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "electron/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "axios": "^1.13.6",
    "chart.js": "^4.5.1",
    "lucide-react": "^0.576.0",
    "react": "^19.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  }
}
